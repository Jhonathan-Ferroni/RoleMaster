*.user
*.suo
*.userosscache
*.sln.docstates
.vs/
.vscode/

# NuGet
*.nupkg
.nuget/packages/
project.lock.json
project.fragment.lock.json
artifacts/

# Dotnet publish
publish/
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.pdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlh
*.tli
*.tmp
*.log
