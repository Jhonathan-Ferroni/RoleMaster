*.vssscc

# ASP.NET / appsettings locais e secrets
appsettings.Local.json
appsettings.*.Local.json
appsettings.*.Development.json
appsettings.json
appsettings.Development.json
*.Secrets.json
launchSettings.json
secrets.json
.env
.env.*

# React / Node
node_modules/
build/
dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
pnpm-lock.yaml

# Misc
.DS_Store
Thumbs.db

# Logs
*.log

# Editor backups
*~
*.swp
*.swo

# Protege strings de conexão e dados sensíveis locais
# Use arquivos de ambiente ou appsettings locais não versionados para credenciais e connection strings.
